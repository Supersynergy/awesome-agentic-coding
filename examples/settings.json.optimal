{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(python3 -m pytest*)",
      "Bash(python3 -m pylint*)",
      "Bash(python3 -m mypy*)",
      "Bash(python3 -c *)",
      "Bash(go test*)",
      "Bash(go build*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo clippy*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(curl -s *)",
      "Bash(claude --version*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/context-inject.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/secret-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/protect-prod.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/syntax-check.sh\""
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "showTurnDuration": true,
  "skipDangerousModePermissionPrompt": true
}
